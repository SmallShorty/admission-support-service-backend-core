// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id           String        @id @default(uuid()) @db.Uuid
  externalId   String?       @map("external_id") @db.VarChar
  lastName     String        @map("last_name") @db.VarChar
  firstName    String        @map("first_name") @db.VarChar
  middleName   String?       @map("middle_name") @db.VarChar
  email        String        @unique @db.VarChar
  authProvider AuthProvider  @map("auth_provider")
  role         AccountRole?
  passwordHash String?       @map("password_hash") @db.VarChar(255)
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime?     @default(now()) @map("updated_at") @db.Timestamp(6)

  // Relations
  applicant           Applicant?
  escalationFromAgent EscalationTicketAudit[] @relation("escalation_from_agent")
  escalationToAgent   EscalationTicketAudit[] @relation("escalation_to_agent")
  ticketMessages      TicketMessage[]
  ticketsAsAgent      Ticket[]                @relation("tickets_agent")
  ticketsAsApplicant  Ticket[]                @relation("tickets_applicant")
  userConnections     UserConnection[]
  templates           Template[]              @relation("template_creator")

  @@map("accounts")
}

model Applicant {
  id                         String    @id @db.Uuid
  snils                      String?   @unique @db.VarChar(14)
  hasBvi                     Boolean?  @default(false) @map("has_bvi")
  hasSpecialQuota            Boolean?  @default(false) @map("has_special_quota")
  hasSeparateQuota           Boolean?  @default(false) @map("has_separate_quota")
  hasTargetQuota             Boolean?  @default(false) @map("has_target_quota")
  hasPriorityRight           Boolean?  @default(false) @map("has_priority_right")
  originalDocumentReceived   Boolean?  @default(false) @map("original_document_received")
  originalDocumentReceivedAt DateTime? @map("original_document_received_at") @db.Timestamp(6)

  applicantPrograms ApplicantProgram[]
  account           Account            @relation(fields: [id], references: [id], onDelete: Cascade)
  examScores        ExamScore[]

  @@map("applicants")
}

model ApplicantProgram {
  id            BigInt        @id @default(autoincrement())
  applicantId   String        @map("applicant_id") @db.Uuid
  programId     Int           @map("program_id")
  programCode   String        @map("program_code") @db.VarChar(20)
  studyForm     StudyForm     @map("study_form")
  admissionType AdmissionType @map("admission_type")
  priority      Int           @db.SmallInt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("applicant_programs")
}

model EscalationTicketAudit {
  id           BigInt          @id @default(autoincrement())
  ticketId     String          @map("ticket_id") @db.Uuid
  fromAgentId  String          @map("from_agent_id") @db.Uuid
  toAgentId    String          @map("to_agent_id") @db.Uuid
  cause        EscalationCause
  causeComment String?         @map("cause_comment")
  escalatedAt  DateTime?       @default(now()) @map("escalated_at") @db.Timestamp(6)
  acceptedAt   DateTime?       @map("accepted_at") @db.Timestamp(6)

  fromAgent Account @relation("escalation_from_agent", fields: [fromAgentId], references: [id])
  toAgent   Account @relation("escalation_to_agent", fields: [toAgentId], references: [id])
  ticket    Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([fromAgentId], map: "idx_escalation_from")
  @@map("escalation_ticket_audit")
}

model ExamScore {
  id          BigInt    @id @default(autoincrement())
  applicantId String    @map("applicant_id") @db.Uuid
  subjectName String    @map("subject_name") @db.VarChar(100)
  score       Int
  type        ExamType?

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@map("exam_scores")
}

model TicketMessage {
  id          BigInt          @id @default(autoincrement())
  ticketId    String          @map("ticket_id") @db.Uuid
  authorId    String          @map("author_id") @db.Uuid
  authorType  MessageType     @map("author_type")
  content     String
  status      DeliveryStatus? @default(SENT)
  deliveredAt DateTime?       @map("delivered_at") @db.Timestamp(6)
  seenAt      DateTime?       @map("seen_at") @db.Timestamp(6)
  createdAt   DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)

  author Account @relation(fields: [authorId], references: [id])
  ticket Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([authorId])
  @@map("ticket_messages")
}

model Ticket {
  id                String                   @id @db.Uuid
  applicantId       String                   @map("applicant_id") @db.Uuid
  agentId           String?                  @map("agent_id") @db.Uuid
  status            TicketStatus             @default(NEW)
  priority          Int?                     @default(0) @db.SmallInt
  intent            AdmissionIntentCategory?
  confidence        Float?                   @map("confidence") @db.DoublePrecision
  noteText          String                   @map("note_text")
  assignedAt        DateTime?                @map("assigned_at") @db.Timestamp(6)
  firstReplyAt      DateTime?                @map("first_reply_at") @db.Timestamp(6)
  resolvedAt        DateTime?                @map("resolved_at") @db.Timestamp(6)
  closedAt          DateTime?                @map("closed_at") @db.Timestamp(6)
  satisfactionScore SatisfactionScore?       @map("satisfaction_score")
  createdAt         DateTime?                @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?                @default(now()) @map("updated_at") @db.Timestamp(6)
  lastMessageAt     DateTime?                @map("last_message_at") @db.Timestamp(6)

  escalations EscalationTicketAudit[]
  messages    TicketMessage[]
  agent       Account?                @relation("tickets_agent", fields: [agentId], references: [id])
  applicant   Account                 @relation("tickets_applicant", fields: [applicantId], references: [id])

  @@index([status, priority, lastMessageAt])
  @@index([status, agentId])
  @@index([status, priority])
  @@index([agentId, status])
  @@index([applicantId])
  @@map("tickets")
}

model UserConnection {
  id             String    @id @default(uuid()) @db.Uuid
  accountId      String    @map("account_id") @db.Uuid
  socketId       String    @map("socket_id")
  connectedAt    DateTime  @default(now()) @map("connected_at") @db.Timestamp(6)
  disconnectedAt DateTime? @map("disconnected_at") @db.Timestamp(6)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([socketId])
  @@map("user_connections")
}

model Template {
  id String @id @default(uuid()) @db.Uuid

  alias String @unique @db.VarChar(50)

  title String @db.VarChar(255)

  // Поддержка Rich Text (хранение JSON или HTML структуры)
  content Json @db.JsonB

  category AdmissionIntentCategory @map("category")
  isActive Boolean                 @default(true) @map("is_active")

  createdBy String   @map("created_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  creator Account @relation("template_creator", fields: [createdBy], references: [id])

  @@index([alias])
  @@map("templates")
}

model DynamicVariable {
  id String @id @default(uuid()) @db.Uuid

  name String @unique @db.VarChar(50)

  description String? @db.VarChar(255)
  sourceField String  @map("source_field")

  fallbackText String @map("fallback_text")

  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("dynamic_variables")
}

model Integration {
  id        String @id @default(uuid()) @db.Uuid
  slug      String @unique @db.VarChar(100)
  name      String @db.VarChar(255)
  eventType IntegrationEventType @map("event_type")

  theme   String @db.VarChar(100)
  source  String @db.VarChar(255)
  content Json   @db.JsonB

  isActive Boolean @default(true) @map("is_active")

  isTypeEditable    Boolean @default(true) @map("is_type_editable")
  isThemeEditable   Boolean @default(true) @map("is_theme_editable")
  isSourceEditable  Boolean @default(true) @map("is_source_editable")
  isContentEditable Boolean @default(true) @map("is_content_editable")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt      @map("updated_at") @db.Timestamp(6)

  notifications Notification[]

  @@index([name])
  @@index([eventType])
  @@map("integrations")
}

model Notification {
  id            String             @id @default(uuid()) @db.Uuid
  integrationId String             @map("integration_id") @db.Uuid
  payload       Json               @db.JsonB
  status        NotificationStatus @default(PENDING)
  error         String?            @db.Text
  sentAt        DateTime?          @map("sent_at") @db.Timestamp(6)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamp(6)

  integration Integration @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@index([status])
  @@map("notifications")
}

model AnalyticsSnapshot {
  id         String   @id @default(uuid()) @db.Uuid
  metricName String   @map("metric_name") @db.VarChar(50)
  agentId    String?  @map("agent_id") @db.Uuid
  value      Float
  timestamp  DateTime @default(now())

  @@index([metricName, agentId, timestamp])
  @@map("analytics_snapshots")
}

model AuditLog {
  id         String        @id @default(uuid()) @db.Uuid
  action     AuditAction
  category   AuditCategory
  severity   LogSeverity
  actor      Json?         @db.JsonB
  targetId   String?       @map("target_id")
  targetType String?       @map("target_type")
  metadata   Json?         @db.JsonB
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([action])
  @@index([category])
  @@index([severity])
  @@index([createdAt])
  @@map("audit_logs")
}

model IntegrationLog {
  id            String            @id @default(uuid()) @db.Uuid
  integrationId String?           @map("integration_id") @db.Uuid
  slug          String?
  action        IntegrationAction
  severity      LogSeverity
  actor         Json?             @db.JsonB
  metadata      Json?             @db.JsonB
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([action])
  @@index([severity])
  @@index([integrationId])
  @@index([slug])
  @@index([createdAt])
  @@map("integration_logs")
}

// Enums (остаются без изменений, так как они обычно в UPPER_CASE)

enum AccountRole {
  ADMIN
  OPERATOR
  SUPERVISOR
  APPLICANT
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum AdmissionIntentCategory {
  TECHNICAL_ISSUES
  DEADLINES_TIMELINES
  DOCUMENT_SUBMISSION
  STATUS_VERIFICATION
  SCORES_COMPETITION
  PAYMENTS_CONTRACTS
  ENROLLMENT
  DORMITORY_HOUSING
  STUDIES_SCHEDULE
  EVENTS
  GENERAL_INFO
  PROGRAM_CONSULTATION
}

enum AdmissionType {
  BUDGET_COMPETITIVE
  BUDGET_BVI
  BUDGET_SPECIAL_QUOTA
  BUDGET_SEPARATE_QUOTA
  TARGET
  PAID
}

enum AuthProvider {
  INTERNAL
  EXTERNAL
}

enum DeliveryStatus {
  SENT
  DELIVERED
  SEEN
}

enum EscalationCause {
  COMPLEX_ISSUE
  INSUFFICIENT_RIGHTS
  CUSTOMER_COMPLAINT
  TECHNICAL_FAILURE
  TIMEOUT
  OTHER
}

enum ExamType {
  EGE
  INTERNAL
}

enum MessageType {
  FROM_CUSTOMER
  FROM_AGENT
  SYSTEM
}

enum SatisfactionScore {
  TERRIBLE
  POOR
  AVERAGE
  GOOD
  EXCELLENT
}

enum StudyForm {
  FULL_TIME
  PART_TIME
  EVENING
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
  AWAITING_FEEDBACK
}

enum IntegrationEventType {
  INFORMATIONAL
  FAILURE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum LogSeverity {
  INFO
  WARN
  ERROR
}

enum AuditCategory {
  AUTH
  ACCOUNT
  TICKET
  TEMPLATE
  SECURITY
  MESSAGING
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  TOKEN_REFRESH_FAILED
  LOGOUT
  ACCOUNT_REGISTERED
  ACCOUNT_UPDATED
  TICKET_TAKEN
  TICKET_ESCALATED
  TICKET_STATUS_CHANGED
  TEMPLATE_CREATED
  TEMPLATE_UPDATED
  TEMPLATE_ACTIVATED
  TEMPLATE_DEACTIVATED
  TICKET_ACCESS_FORBIDDEN
  TICKET_ESCALATION_FORBIDDEN
  MESSAGE_VARIABLE_RESOLUTION_FAILED
}

enum IntegrationAction {
  INTEGRATION_CREATED
  INTEGRATION_UPDATED
  INTEGRATION_ACTIVATED
  INTEGRATION_DEACTIVATED
  INTEGRATION_SUBMITTED
  INTEGRATION_SUBMISSION_NOT_FOUND
  INTEGRATION_SUBMISSION_READONLY_FIELD_VIOLATION
}
